{
	"name": "@repo/data-ops",
	"version": "1.0.0",
	"description": "Manage auth, database, schemas, and queries",
	"exports": {
		"./auth/*": {
			"types": "./dist/auth/*.d.ts",
			"default": "./dist/auth/*.js"
		},
		"./database/*": {
			"types": "./dist/database/*.d.ts",
			"default": "./dist/database/*.js"
		},
		"./zod-schema/*": {
			"types": "./dist/zod-schema/*.d.ts",
			"default": "./dist/zod-schema/*.js"
		},
		"./queries/*": {
			"types": "./dist/queries/*.d.ts",
			"default": "./dist/queries/*.js"
		},
		"./lib/*": {
			"types": "./dist/lib/*.d.ts",
			"default": "./dist/lib/*.js"
		},
		"./channels/*": {
			"types": "./dist/channels/*.d.ts",
			"default": "./dist/channels/*.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json --outDir ./dist && tsc-alias",
		"test": "vitest",
		"better-auth:generate": "mkdir -p src/drizzle && npx @better-auth/cli@latest generate --config ./config/auth.ts --output ./src/drizzle/auth-schema.ts",
		"drizzle:dev:generate": "dotenvx run -f .env.dev -- drizzle-kit generate --config drizzle-dev.config.ts",
		"drizzle:dev:migrate": "dotenvx run -f .env.dev -- drizzle-kit migrate --config drizzle-dev.config.ts",
		"drizzle:dev:pull": "dotenvx run -f .env.dev -- drizzle-kit pull --config drizzle-dev.config.ts",
		"drizzle:stage:generate": "dotenvx run -f .env.stage -- drizzle-kit generate --config drizzle-stage.config.ts",
		"drizzle:stage:migrate": "dotenvx run -f .env.stage -- drizzle-kit migrate --config drizzle-stage.config.ts",
		"drizzle:stage:pull": "dotenvx run -f .env.stage -- drizzle-kit pull --config drizzle-stage.config.ts",
		"drizzle:prod:generate": "dotenvx run -f .env.prod -- drizzle-kit generate --config drizzle-prod.config.ts",
		"drizzle:prod:migrate": "dotenvx run -f .env.prod -- drizzle-kit migrate --config drizzle-prod.config.ts",
		"drizzle:prod:pull": "dotenvx run -f .env.prod -- drizzle-kit pull --config drizzle-prod.config.ts",
		"clear:dev": "dotenvx run -f .env.dev -- tsx scripts/clear-data.ts",
		"clear:stage": "dotenvx run -f .env.stage -- tsx scripts/clear-data.ts",
		"clear:prod": "dotenvx run -f .env.prod -- tsx scripts/clear-data.ts",
		"seed:dev": "dotenvx run -f .env.dev -- tsx scripts/seed.ts",
		"seed:stage": "dotenvx run -f .env.stage -- tsx scripts/seed.ts",
		"seed:prod": "dotenvx run -f .env.prod -- tsx scripts/seed.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.33.2",
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0",
		"better-auth": "^1.6.9",
		"drizzle-orm": "^0.44.7",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260424.1",
		"@electric-sql/pglite": "^0.2.17",
		"@repo/test-harness": "workspace:*",
		"drizzle-kit": "^0.31.10",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	}
}
