{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignoreDependencies": ["cloudflare"],
	"ignore": ["**/auth-schema.ts", "packages/data-ops/src/drizzle/auth-schema.ts"],
	"workspaces": {
		".": {},
		"apps/data-service": {
			"ignoreDependencies": []
		},
		"apps/user-application": {
			"entry": ["src/start.tsx", "src/router.tsx", "src/routes/**/*.{ts,tsx}"],
			"ignoreDependencies": ["web-vitals", "@types/remark-prism"],
			"ignore": ["src/components/ui/**", "src/integrations/**"]
		},
		"packages/data-ops": {
			"entry": [
				"src/auth/*.ts",
				"src/database/*.ts",
				"src/queries/*.ts",
				"src/zod-schema/*.ts",
				"src/lib/*.ts",
				"config/auth.ts",
				"drizzle-*.config.ts"
			],
			"ignoreBinaries": ["dotenvx"]
		},
		"packages/test-harness": {
			"entry": ["tests/**/*.test.ts"]
		}
	}
}
