{
	"name": "user-application",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build:stage": "vite build --mode stage",
		"build:prod": "vite build --mode prod",
		"deploy:stage": "pnpm run build:stage && wrangler deploy --env=''",
		"deploy:prod": "pnpm run build:prod && wrangler deploy --env=''",
		"sync-secrets:stage": "./sync-secrets.sh stage",
		"sync-secrets:prod": "./sync-secrets.sh prod",
		"serve": "vite preview",
		"types": "tsc --noEmit",
		"cf-typegen": "wrangler types --env-interface Env --env dev"
	},
	"dependencies": {
		"@radix-ui/react-avatar": "^1.1.11",
